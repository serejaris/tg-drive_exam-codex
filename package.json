{
  "name": "tg-drive_exam-codex",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "start:railway": "prisma migrate deploy && npm run db:seed && npm run bot:webhook:set && next start -p ${PORT:-3000}",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "bot:webhook:set": "tsx scripts/set-webhook.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "next": "16.2.4",
    "prisma": "6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "telegraf": "^4.16.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.0"
  }
}
